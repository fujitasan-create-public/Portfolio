---
import IntroSplash from "../components/IntroSplash";
import HomeIntro from "../components/HomeIntro.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fujita-create Portfolio</title>
    <meta
      name="description"
      content="Fujita-createのポートフォリオサイト。Web制作における設計方針、スキル、実績、最新情報を掲載します。"
    />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Fujita-create Portfolio" />
    <meta
      property="og:description"
      content="Fujita-createのポートフォリオサイト。アクセシビリティと構造化を重視したWeb制作を紹介します。"
    />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Fujita-create Portfolio" />
    <meta
      name="twitter:description"
      content="アクセシビリティと構造化を重視したFujita-createのポートフォリオ。"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;800&family=Space+Grotesk:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "name": "Fujita-create Portfolio",
        "inLanguage": "ja",
        "mainEntity": {
          "@type": "Person",
          "name": "Fujita-create",
          "url": "/"
        }
      }
    </script>
  </head>
  <body>
    <main>
      <IntroSplash client:load>
        <HomeIntro />
      </IntroSplash>
    </main>
  </body>
</html>
